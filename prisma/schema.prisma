generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  emailVerified DateTime? 
  image    String?
  password String?
  timezone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  sessions              Session[]
  commitments           Commitment[]
  notifications         Notification[]
  activityLogs          ActivityLog[]
  chatMessages          ChatMessage[]
  connections           Connection[]
  conversationSources   ConversationSource[]
  contextMemories       ContextMemory[]
  roadmapCache          RoadmapCache?
}

model Commitment {
  id              String             @id @default(cuid())
  userId          String
  title           String
  description     String?
  category        Category
  priority        Priority
  status          CommitmentStatus
  deadline        DateTime?
  riskScore       Int                @default(0)
  confidenceScore Int?
  estimatedEffort Int?
  aiSummary       String?
  lastActivity    DateTime?
  calendarEventId String?
  calendarSynced  Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  sources         CommitmentSource[]
  actionPlans     ActionPlan[]
  notifications   Notification[]
  activityLogs    ActivityLog[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([deadline])
  @@index([riskScore])
}

enum Category {
  ACADEMIC
  CAREER
  PERSONAL
  FINANCE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommitmentStatus {
  DISCOVERED
  ACTIVE
  AT_RISK
  COMPLETED
  MISSED
  ARCHIVED
}

model CommitmentSource {
  id              String     @id @default(cuid())
  commitmentId    String
  sourceType      SourceType
  sourceReference String?
  rawContent      String?
  createdAt       DateTime   @default(now())

  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
}

enum SourceType {
  GMAIL
  CALENDAR
  DOCUMENT
  MANUAL
}

model ActionPlan {
  id           String   @id @default(cuid())
  commitmentId String
  title        String?
  planContent  String
  createdAt    DateTime @default(now())

  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  REMINDER
  DEADLINE_WARNING
  STATUS_UPDATE
  RECOMMENDATION
  ALERT
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  commitmentId String?
  title        String
  message      String
  type         NotificationType
  isRead       Boolean          @default(false)
  createdAt    DateTime         @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitment Commitment? @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
}

enum ActivityType {
  CREATED
  UPDATED
  COMPLETED
  MISSED
  REMINDER_SENT
  AI_SUMMARY_GENERATED
  ACTION_PLAN_CREATED
}

model ActivityLog {
  id           String       @id @default(cuid())
  userId       String
  commitmentId String?
  activityType ActivityType
  metadata     Json?
  createdAt    DateTime     @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitment Commitment? @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
}

enum ChatRole {
  USER
  ASSISTANT
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      ChatRole
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Connection {
  id                String   @id @default(cuid())
  userId            String

  provider          String
  providerAccountId String
  email             String

  accessToken       String? @db.Text
  refreshToken      String? @db.Text
  expiresAt         DateTime? 

  connected         Boolean @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── Browser Extension Pipeline ───────────────────────────────────

enum ConversationPlatform {
  CHATGPT
  CLAUDE
  GEMINI
}

enum ContextStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model ConversationSource {
  id                     String               @id @default(cuid())
  userId                 String
  source                 ConversationPlatform
  externalConversationId String?
  title                  String
  summary                String?
  rawData                Json
  processed              Boolean              @default(false)
  ignoredContextName     String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([processed])
  @@index([ignoredContextName])
}

model ContextMemory {
  id             String        @id @default(cuid())
  userId         String
  contextName    String
  source         String
  status         ContextStatus @default(ACTIVE)
  completed      Json          @default("[]")
  lastCheckpoint String?
  nextAction     String?
  estimatedTime  Int?
  priority       Int           @default(0)
  lastWorkedAt   DateTime?
  summary        String?
  deleted        Boolean       @default(false)
  deletedAt      DateTime?
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([deleted])
}

model RoadmapCache {
  id          String   @id @default(cuid())
  userId      String   @unique
  result      Json
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
